# Copy this file to deploy/secrets.env and fill in the values.
# deploy.sh turns it into the `forge-secrets` Kubernetes secret.
# NEVER commit secrets.env (it is gitignored).

# --- Mistral (free key from https://console.mistral.ai) ---
MISTRAL_API_KEY=

# --- MongoDB Atlas (free M0 cluster from https://www.mongodb.com/atlas) ---
# You can use the same cluster with two database names.
AUTH_MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/auth
SANDBOX_MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sandbox

# --- Google OAuth (https://console.cloud.google.com -> APIs & Services -> Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed for email notifications (Gmail API). Leave dummy if unused.
GOOGLE_REFRESH_TOKEN=unused
EMAIL_USER=you@gmail.com

# --- App secret: any long random string ---
JWT_SECRET=

# --- In-cluster services (defaults are correct, do not change) ---
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://rabbitmq:5672
