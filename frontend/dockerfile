FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

# Public host the deployed app is reachable on, e.g. 140-245-12-34.sslip.io
# Baked into the bundle at build time (used to reach <sandboxId>.agent.<host>)
ARG VITE_PUBLIC_BASE_HOST
ENV VITE_PUBLIC_BASE_HOST=$VITE_PUBLIC_BASE_HOST

RUN npm run build


FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
